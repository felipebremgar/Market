<Window x:Class="Market.UI.Views.CadastrarClienteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Novo Cliente" Height="300" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <StackPanel Margin="20">
        <TextBlock Text="Cadastro de Cliente" FontSize="18" FontWeight="Bold"/>

        <TextBlock Text="CPF *" Margin="0,14,0,3" Foreground="#4C566A"/>
        <TextBox x:Name="TxtCpf" Height="30" Padding="6,3" VerticalContentAlignment="Center"
                 MaxLength="14"/>

        <TextBlock Text="Nome *" Margin="0,12,0,3" Foreground="#4C566A"/>
        <TextBox x:Name="TxtNome" Height="30" Padding="6,3" VerticalContentAlignment="Center"
                 MaxLength="120"/>

        <Border x:Name="PainelMensagem" Visibility="Collapsed" Margin="0,14,0,0"
                Padding="10,8" CornerRadius="4">
            <TextBlock x:Name="TxtMensagem" TextWrapping="Wrap"/>
        </Border>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button x:Name="BtnSalvar" Content="Salvar" Width="100" Height="34"
                    Click="BtnSalvar_Click" IsDefault="True"/>
            <Button Content="Cancelar" Width="100" Height="34" Margin="10,0,0,0"
                    Click="BtnCancelar_Click" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
