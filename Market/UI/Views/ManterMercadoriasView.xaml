<UserControl x:Class="Market.UI.Views.ManterMercadoriasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ctrls="clr-namespace:Market.UI.Controls"
             mc:Ignorable="d" d:DesignWidth="640" d:DesignHeight="480">
    <DockPanel Margin="16">
        <TextBlock DockPanel.Dock="Top" Text="Manter Mercadorias"
                   FontSize="22" FontWeight="Bold"/>
        <TextBlock DockPanel.Dock="Top" x:Name="TxtContador"
                   Foreground="Gray" Margin="0,4,0,10"/>

        <!-- Painel de filtros -->
        <Border DockPanel.Dock="Top" Background="#F5F6F8" CornerRadius="4"
                Padding="12" Margin="0,0,0,10">
            <StackPanel>
                <UniformGrid Columns="4">
                    <StackPanel Margin="0,0,10,8">
                        <TextBlock Text="Nome" FontSize="12" Foreground="#4C566A"/>
                        <TextBox x:Name="FiltroNome" KeyDown="Filtro_KeyDown"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,10,8">
                        <TextBlock Text="Fornecedor" FontSize="12" Foreground="#4C566A"/>
                        <TextBox x:Name="FiltroFornecedor" KeyDown="Filtro_KeyDown"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,10,8">
                        <TextBlock Text="Código de barras (bipe aqui)" FontSize="12" Foreground="#4C566A"/>
                        <TextBox x:Name="FiltroCodigoBarras" KeyDown="FiltroCodigoBarras_KeyDown"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,10,8">
                        <TextBlock Text="Quantidade mínima" FontSize="12" Foreground="#4C566A"/>
                        <TextBox x:Name="FiltroQtdMin" KeyDown="Filtro_KeyDown"
                                 PreviewTextInput="Inteiro_PreviewTextInput"
                                 DataObject.Pasting="Inteiro_Pasting"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,10,8">
                        <TextBlock Text="Preço venda mín (R$)" FontSize="12" Foreground="#4C566A"/>
                        <TextBox x:Name="FiltroPrecoMin" KeyDown="Filtro_KeyDown"
                                 PreviewTextInput="Decimal_PreviewTextInput"
                                 DataObject.Pasting="Decimal_Pasting"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,10,8">
                        <TextBlock Text="Preço venda máx (R$)" FontSize="12" Foreground="#4C566A"/>
                        <TextBox x:Name="FiltroPrecoMax" KeyDown="Filtro_KeyDown"
                                 PreviewTextInput="Decimal_PreviewTextInput"
                                 DataObject.Pasting="Decimal_Pasting"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,10,8">
                        <TextBlock Text="Validade de" FontSize="12" Foreground="#4C566A"/>
                        <DatePicker x:Name="FiltroValidadeIni"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,10,8">
                        <TextBlock Text="Validade até" FontSize="12" Foreground="#4C566A"/>
                        <DatePicker x:Name="FiltroValidadeFim"/>
                    </StackPanel>
                </UniformGrid>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <Button x:Name="BtnFiltrar" Content="Filtrar" Width="110" Height="32"
                            Click="BtnFiltrar_Click"/>
                    <Button x:Name="BtnLimparFiltros" Content="Limpar filtros" Width="130" Height="32"
                            Margin="10,0,0,0" Click="BtnLimparFiltros_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Mensagens -->
        <ctrls:NotificationBanner DockPanel.Dock="Top" x:Name="Notificacao" Margin="0,0,0,8"/>

        <!-- Ações sobre a seleção -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="BtnEditar" Content="Editar" Width="100" Height="32"
                    Click="BtnEditar_Click"/>
            <Button x:Name="BtnExcluir" Content="Excluir" Width="100" Height="32"
                    Margin="10,0,0,0" Click="BtnExcluir_Click"/>
        </StackPanel>

        <!-- Legenda dos destaques -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
            <TextBlock Text="Legenda:" FontWeight="SemiBold" Margin="0,0,8,0"/>
            <Border Background="#FDECEA" Padding="6,2" Margin="0,0,6,0" CornerRadius="3">
                <TextBlock Text="Vencida"/>
            </Border>
            <Border Background="#FFF4E5" Padding="6,2" Margin="0,0,6,0" CornerRadius="3">
                <TextBlock Text="Vence em ≤ 7 dias"/>
            </Border>
            <Border Background="#FFFDE7" Padding="6,2" Margin="0,0,6,0" CornerRadius="3">
                <TextBlock Text="Estoque baixo"/>
            </Border>
        </StackPanel>

        <DataGrid x:Name="Grid" AutomationProperties.AutomationId="GridMercadorias"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" SelectionMode="Single"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  RowHeaderWidth="0" MouseDoubleClick="Grid_MouseDoubleClick">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <!-- Precedência: o último trigger verdadeiro vence (estoque < vence < vencida). -->
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding EstoqueBaixo}" Value="True">
                            <Setter Property="Background" Value="#FFFDE7"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ProximaDoVencimento}" Value="True">
                            <Setter Property="Background" Value="#FFF4E5"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Vencida}" Value="True">
                            <Setter Property="Background" Value="#FDECEA"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nome" Binding="{Binding Nome}" Width="2*"/>
                <DataGridTextColumn Header="Fornecedor" Binding="{Binding Fornecedor}" Width="*"/>
                <DataGridTextColumn Header="Custo" Binding="{Binding PrecoCustoTexto}" Width="Auto"/>
                <DataGridTextColumn Header="Venda" Binding="{Binding PrecoVendaTexto}" Width="Auto"/>
                <DataGridTextColumn Header="Qtd" Binding="{Binding Quantidade}" Width="Auto"/>
                <DataGridTextColumn Header="Código de barras" Binding="{Binding CodigoBarras}" Width="Auto"/>
                <DataGridTextColumn Header="Validade" Binding="{Binding ValidadeTexto}" Width="Auto"/>
                <DataGridTextColumn Header="Cadastro" Binding="{Binding DataCadastroTexto}" Width="Auto"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
