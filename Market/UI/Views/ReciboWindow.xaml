<Window x:Class="Market.UI.Views.ReciboWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Venda concluída" Height="520" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <DockPanel Margin="20">
        <StackPanel DockPanel.Dock="Top">
            <TextBlock x:Name="TxtTitulo" Text="✔ Venda concluída" FontSize="20" FontWeight="Bold" Foreground="#2E7D32"/>
            <TextBlock x:Name="TxtCabecalho" Foreground="Gray" Margin="0,4,0,0"/>
            <TextBlock x:Name="TxtCliente" Margin="0,2,0,4"/>
            <TextBlock x:Name="TxtPagamento" AutomationProperties.AutomationId="ReciboPagamento"
                       Foreground="#4C566A" Margin="0,0,0,10" TextWrapping="Wrap"
                       Visibility="Collapsed"/>
        </StackPanel>

        <Border DockPanel.Dock="Bottom" Background="#2E3440" CornerRadius="6" Padding="14" Margin="0,12,0,0">
            <Grid>
                <TextBlock Text="TOTAL" Foreground="#88C0D0" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtTotal" AutomationProperties.AutomationId="ReciboTotal"
                           Foreground="White" FontSize="26" FontWeight="Bold" HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <Button DockPanel.Dock="Bottom" x:Name="BtnNovaVenda" Content="Nova venda"
                Height="42" Margin="0,12,0,0" Click="BtnNovaVenda_Click" IsDefault="True"/>

        <DataGrid x:Name="GridItens" AutomationProperties.AutomationId="GridRecibo"
                  AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal" RowHeaderWidth="0"
                  Margin="0,10,0,0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Produto" Binding="{Binding Nome}" Width="*"/>
                <DataGridTextColumn Header="Qtd" Binding="{Binding Quantidade}" Width="Auto"/>
                <DataGridTextColumn Header="Preço" Binding="{Binding PrecoTexto}" Width="Auto"/>
                <DataGridTextColumn Header="Subtotal" Binding="{Binding SubtotalTexto}" Width="Auto"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
