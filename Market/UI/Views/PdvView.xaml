<UserControl x:Class="Market.UI.Views.PdvView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ctrls="clr-namespace:Market.UI.Controls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="560">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="3" Text="Vendas (PDV)"
                   FontSize="22" FontWeight="Bold" Margin="0,0,0,10"/>

        <!-- Entrada -->
        <Border Grid.Row="1" Grid.Column="0" Background="#F5F6F8" CornerRadius="4"
                Padding="12" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Código de barras (bipe o produto)" FontSize="12" Foreground="#4C566A"/>
                    <TextBox x:Name="TxtCodigo" Height="32" VerticalContentAlignment="Center"
                             KeyDown="TxtCodigo_KeyDown"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Buscar por nome (digite para filtrar)" FontSize="12" Foreground="#4C566A"/>
                    <TextBox x:Name="TxtBuscaNome" Height="32" VerticalContentAlignment="Center"
                             TextChanged="TxtBuscaNome_TextChanged" KeyDown="TxtBuscaNome_KeyDown"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Resultados da busca por nome: dropdown que sobrepõe o carrinho.
             ZIndex é necessário porque o GridCarrinho é irmão posterior na mesma célula. -->
        <ListBox Grid.Row="2" Grid.Column="0" x:Name="ListaBusca" Visibility="Collapsed"
                 Panel.ZIndex="1" AutomationProperties.AutomationId="ListaBusca"
                 MouseDoubleClick="ListaBusca_Escolher" KeyDown="ListaBusca_KeyDown"
                 VerticalAlignment="Top" MaxHeight="180" Margin="0,0,0,10"/>

        <!-- Carrinho -->
        <DataGrid Grid.Row="2" Grid.Column="0" x:Name="GridCarrinho"
                  AutomationProperties.AutomationId="GridCarrinho"
                  AutoGenerateColumns="False" IsReadOnly="False" CanUserAddRows="False"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal" RowHeaderWidth="0"
                  SelectionMode="Single" SelectionUnit="FullRow"
                  CellEditEnding="GridCarrinho_CellEditEnding">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Produto" Binding="{Binding Nome}" Width="*" IsReadOnly="True"/>
                <DataGridTextColumn Header="Preço" Binding="{Binding PrecoUnitarioTexto}" Width="Auto" IsReadOnly="True"/>
                <DataGridTextColumn Header="Qtd" Binding="{Binding Quantidade}" Width="60"
                                    x:Name="ColunaQtd"/>
                <DataGridTextColumn Header="Subtotal" Binding="{Binding SubtotalTexto}" Width="Auto" IsReadOnly="True"/>
                <DataGridTemplateColumn Header="" Width="Auto" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="−" Width="28" Margin="2,0" Click="BtnMenos_Click"/>
                                <Button Content="+" Width="28" Margin="2,0" Click="BtnMais_Click"/>
                                <Button Content="Remover" Margin="6,0,2,0" Click="BtnRemover_Click"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Resumo -->
        <Border Grid.Row="1" Grid.Column="2" Grid.RowSpan="2" Background="#2E3440"
                CornerRadius="6" Padding="16">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="TOTAL" Foreground="#88C0D0" FontWeight="Bold"/>
                    <TextBlock x:Name="TxtTotal" AutomationProperties.AutomationId="TxtTotal"
                               Text="R$ 0,00" Foreground="White" FontSize="34" FontWeight="Bold"/>

                    <Separator Margin="0,14" Background="#4C566A"/>

                    <TextBlock Text="Cliente — CPF" Foreground="#88C0D0" FontWeight="Bold"/>
                    <TextBox x:Name="TxtCliente" Height="30" Margin="0,4,0,0"
                             VerticalContentAlignment="Center" KeyDown="TxtCliente_KeyDown"/>

                    <!-- Cliente selecionado: clicável, abre o cadastro para edição -->
                    <Border x:Name="PainelCliente" Visibility="Collapsed" Margin="0,8,0,0"
                            Background="#3B4252" CornerRadius="4" Padding="10,8" Cursor="Hand"
                            AutomationProperties.AutomationId="PainelCliente"
                            ToolTip="Clique para ver/editar os dados do cliente"
                            MouseLeftButtonUp="PainelCliente_Click">
                        <DockPanel>
                            <Button x:Name="BtnRemoverCliente" DockPanel.Dock="Right" Content="✕"
                                    Width="24" Height="24" VerticalAlignment="Top" Padding="0"
                                    ToolTip="Remover cliente da venda" Click="BtnRemoverCliente_Click"/>
                            <StackPanel>
                                <TextBlock x:Name="TxtClienteNome"
                                           AutomationProperties.AutomationId="TxtClienteSelecionado"
                                           Foreground="White" FontSize="15" FontWeight="Bold"
                                           TextWrapping="Wrap"/>
                                <TextBlock x:Name="TxtClienteCpf" Foreground="#A3BE8C" FontSize="13"
                                           Margin="0,2,0,0"/>
                                <TextBlock x:Name="TxtClienteContato" Foreground="#D8DEE9" FontSize="12"
                                           Margin="0,2,0,0" TextWrapping="Wrap"/>
                                <TextBlock Text="✎ clique para editar" Foreground="#88C0D0"
                                           FontSize="11" Margin="0,6,0,0"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom">
                    <ctrls:NotificationBanner x:Name="Notificacao" Margin="0,0,0,8"/>
                    <Button x:Name="BtnFinalizar" Content="Finalizar venda" Margin="0,8,0,0" Height="44"
                            IsEnabled="False" Click="BtnFinalizar_Click"/>
                    <Button x:Name="BtnCancelar" Content="Cancelar venda" Height="32" Margin="0,8,0,0"
                            Click="BtnCancelar_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
