<UserControl x:Class="Market.UI.Views.CadastroMercadoriaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ctrls="clr-namespace:Market.UI.Controls"
             mc:Ignorable="d" d:DesignWidth="640">
    <UserControl.Resources>
        <Style TargetType="TextBlock" x:Key="Rotulo">
            <Setter Property="Margin" Value="0,10,0,3"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#4C566A"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" MaxWidth="560" HorizontalAlignment="Left">
            <TextBlock Text="Cadastro de Mercadoria" FontSize="22" FontWeight="Bold"/>
            <TextBlock Text="Campos com * são obrigatórios."
                       Foreground="Gray" Margin="0,4,0,12"/>

            <!-- Código de barras (foco inicial; leitor HID envia Enter ao final) -->
            <TextBlock Text="Código de barras (bipe o produto ou digite)" Style="{StaticResource Rotulo}"/>
            <TextBox x:Name="TxtCodigoBarras" KeyDown="TxtCodigoBarras_KeyDown"/>

            <TextBlock Text="Nome *" Style="{StaticResource Rotulo}"/>
            <TextBox x:Name="TxtNome" MaxLength="120"/>

            <TextBlock Text="Fornecedor" Style="{StaticResource Rotulo}"/>
            <TextBox x:Name="TxtFornecedor" MaxLength="120"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Preço de custo (R$)" Style="{StaticResource Rotulo}"/>
                    <TextBox x:Name="TxtPrecoCusto" MaxLength="12"
                             PreviewTextInput="Decimal_PreviewTextInput"
                             DataObject.Pasting="Decimal_Pasting"
                             TextChanged="Preco_TextChanged"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Preço de venda (R$)" Style="{StaticResource Rotulo}"/>
                    <TextBox x:Name="TxtPrecoVenda" MaxLength="12"
                             PreviewTextInput="Decimal_PreviewTextInput"
                             DataObject.Pasting="Decimal_Pasting"
                             TextChanged="Preco_TextChanged"/>
                </StackPanel>
            </Grid>

            <!-- Sugestão de preço por margem e margem atual -->
            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Margem alvo (%)" VerticalAlignment="Center"
                           Foreground="#4C566A" Margin="0,0,8,0"/>
                <TextBox Grid.Column="1" x:Name="TxtMargem" Text="25" MaxLength="4"
                         PreviewTextInput="Inteiro_PreviewTextInput"
                         DataObject.Pasting="Inteiro_Pasting"/>
                <Button Grid.Column="2" x:Name="BtnSugerir" Content="Sugerir preço de venda"
                        Height="32" Margin="10,0,0,0" Padding="10,0" Click="BtnSugerir_Click"/>
                <TextBlock Grid.Column="3" x:Name="TxtMargemAtual" VerticalAlignment="Center"
                           Margin="16,0,0,0" FontWeight="SemiBold"/>
            </Grid>

            <TextBlock Text="Quantidade em estoque" Style="{StaticResource Rotulo}"/>
            <TextBox x:Name="TxtQuantidade" MaxLength="7" Text="0"
                     PreviewTextInput="Inteiro_PreviewTextInput"
                     DataObject.Pasting="Inteiro_Pasting"/>

            <CheckBox x:Name="ChkPossuiValidade" Content="Possui validade"
                      Margin="0,16,0,0" Checked="ChkPossuiValidade_Changed"
                      Unchecked="ChkPossuiValidade_Changed"/>
            <DatePicker x:Name="DtValidade" IsEnabled="False" Margin="0,6,0,0"
                        HorizontalAlignment="Left" Width="180"/>

            <!-- Mensagens -->
            <ctrls:NotificationBanner x:Name="Notificacao" Margin="0,18,0,0"/>

            <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                <Button x:Name="BtnSalvar" Content="Salvar" Width="120" Height="38"
                        Click="BtnSalvar_Click" IsDefault="True"/>
                <Button x:Name="BtnLimpar" Content="Limpar" Width="120" Height="38"
                        Margin="12,0,0,0" Click="BtnLimpar_Click"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
