<UserControl x:Class="Market.UI.Views.ClientesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ctrls="clr-namespace:Market.UI.Controls"
             mc:Ignorable="d" d:DesignWidth="640" d:DesignHeight="480">
    <DockPanel Margin="16">
        <TextBlock DockPanel.Dock="Top" Text="Clientes" FontSize="22" FontWeight="Bold"/>
        <TextBlock DockPanel.Dock="Top" x:Name="TxtContador" Foreground="Gray" Margin="0,4,0,10"/>

        <!-- Busca -->
        <Border DockPanel.Dock="Top" Background="#F5F6F8" CornerRadius="4" Padding="12" Margin="0,0,0,10">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="CPF" FontSize="13" Foreground="#4C566A"/>
                        <TextBox x:Name="BuscaCpf" KeyDown="Busca_KeyDown"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Nome" FontSize="13" Foreground="#4C566A"/>
                        <TextBox x:Name="BuscaNome" KeyDown="Busca_KeyDown"/>
                    </StackPanel>
                </Grid>
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <Button x:Name="BtnBuscar" Content="Buscar" Width="110" Height="32" Click="BtnBuscar_Click"/>
                    <Button x:Name="BtnLimpar" Content="Limpar" Width="110" Height="32"
                            Margin="10,0,0,0" Click="BtnLimpar_Click"/>
                    <Button x:Name="BtnNovo" Content="Novo cliente" Width="130" Height="32"
                            Margin="10,0,0,0" Click="BtnNovo_Click"/>
                    <Button x:Name="BtnEditar" Content="Editar" Width="110" Height="32"
                            Margin="10,0,0,0" Click="BtnEditar_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <ctrls:NotificationBanner DockPanel.Dock="Top" x:Name="Notificacao" Margin="0,0,0,8"/>

        <Grid>
        <DataGrid x:Name="Grid" AutomationProperties.AutomationId="GridClientes"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" SelectionMode="Single"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal" RowHeaderWidth="0"
                  MouseDoubleClick="Grid_MouseDoubleClick"
                  PreviewMouseRightButtonDown="Grid_PreviewMouseRightButtonDown">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Editar" Click="BtnEditar_Click"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTextColumn Header="CPF" Binding="{Binding Cpf}" Width="Auto"/>
                <DataGridTextColumn Header="Nome" Binding="{Binding Nome}" Width="*"/>
                <DataGridTextColumn Header="Contato" Binding="{Binding Contato}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
        <TextBlock Style="{StaticResource EmptyState}" Text="Nenhum cliente encontrado."
                   Visibility="{Binding HasItems, ElementName=Grid, Converter={StaticResource BoolInverteVis}}"/>
        </Grid>
    </DockPanel>
</UserControl>
