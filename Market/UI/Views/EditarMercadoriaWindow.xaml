<Window x:Class="Market.UI.Views.EditarMercadoriaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ctrls="clr-namespace:Market.UI.Controls"
        mc:Ignorable="d"
        Title="Editar Mercadoria" Height="560" Width="460"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="Rotulo">
            <Setter Property="Margin" Value="0,10,0,3"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#4C566A"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock x:Name="TxtCabecalho" FontSize="16" FontWeight="Bold"/>

                <TextBlock Text="Código de barras" Style="{StaticResource Rotulo}"/>
                <TextBox x:Name="TxtCodigoBarras"/>

                <TextBlock Text="Nome *" Style="{StaticResource Rotulo}"/>
                <TextBox x:Name="TxtNome" MaxLength="120"/>

                <TextBlock Text="Fornecedor" Style="{StaticResource Rotulo}"/>
                <TextBox x:Name="TxtFornecedor" MaxLength="120"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Preço de custo (R$)" Style="{StaticResource Rotulo}"/>
                        <TextBox x:Name="TxtPrecoCusto" MaxLength="12"
                                 PreviewTextInput="Decimal_PreviewTextInput"
                                 DataObject.Pasting="Decimal_Pasting"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Preço de venda (R$)" Style="{StaticResource Rotulo}"/>
                        <TextBox x:Name="TxtPrecoVenda" MaxLength="12"
                                 PreviewTextInput="Decimal_PreviewTextInput"
                                 DataObject.Pasting="Decimal_Pasting"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Quantidade em estoque" Style="{StaticResource Rotulo}"/>
                <TextBox x:Name="TxtQuantidade" MaxLength="7"
                         PreviewTextInput="Inteiro_PreviewTextInput"
                         DataObject.Pasting="Inteiro_Pasting"/>

                <CheckBox x:Name="ChkPossuiValidade" Content="Possui validade" Margin="0,16,0,0"
                          Checked="ChkPossuiValidade_Changed" Unchecked="ChkPossuiValidade_Changed"/>
                <DatePicker x:Name="DtValidade" IsEnabled="False" Margin="0,6,0,0"
                            HorizontalAlignment="Left" Width="180"/>

                <TextBlock x:Name="TxtCadastro" Foreground="Gray" FontSize="12" Margin="0,14,0,0"/>

                <ctrls:NotificationBanner x:Name="Notificacao" Margin="0,14,0,0"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="BtnSalvar" Content="Salvar" Width="110" Height="36"
                    Click="BtnSalvar_Click" IsDefault="True"/>
            <Button Content="Cancelar" Width="110" Height="36" Margin="10,0,0,0"
                    Click="BtnCancelar_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
