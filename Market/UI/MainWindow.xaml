<Window x:Class="Market.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Mercadinho — Sistema de Logística"
        Height="560" Width="900"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="Button" x:Key="NavButton">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Margin" Value="8,2"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#ECEFF4"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3B4252"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#6B7280"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Menu lateral -->
        <Border Grid.Column="0" Background="#2E3440">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="MERCADINHO"
                           Foreground="#88C0D0" FontWeight="Bold" FontSize="16"
                           Margin="16,20,16,20"/>

                <StackPanel DockPanel.Dock="Top">
                    <Button x:Name="BtnInicio" Style="{StaticResource NavButton}"
                            Content="🏠  Início" Click="BtnInicio_Click"/>
                    <Button x:Name="BtnCadastroMercadoria" Style="{StaticResource NavButton}"
                            Content="➕  Cadastro de Mercadoria" Click="BtnCadastroMercadoria_Click"/>
                    <Button x:Name="BtnManterMercadorias" Style="{StaticResource NavButton}"
                            Content="📦  Manter Mercadorias" Click="BtnManterMercadorias_Click"/>
                    <Button x:Name="BtnClientes" Style="{StaticResource NavButton}"
                            Content="👥  Clientes" Click="BtnClientes_Click"/>
                    <Button x:Name="BtnPdv" Style="{StaticResource NavButton}"
                            Content="🛒  Vendas (PDV)" Click="BtnPdv_Click"/>
                    <Button x:Name="BtnHistorico" Style="{StaticResource NavButton}"
                            Content="📜  Histórico de Vendas" Click="BtnHistorico_Click"/>
                    <Button Style="{StaticResource NavButton}" Content="📊  Relatório de Lucros" IsEnabled="False"/>
                </StackPanel>

                <TextBlock DockPanel.Dock="Bottom" Text="v1 — em desenvolvimento"
                           Foreground="#4C566A" FontSize="11" Margin="16,0,16,12"
                           VerticalAlignment="Bottom"/>
            </DockPanel>
        </Border>

        <!-- Conteúdo -->
        <ContentControl x:Name="ContentArea" Grid.Column="1"/>
    </Grid>
</Window>
