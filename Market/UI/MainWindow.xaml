<Window x:Class="Market.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Mercadinho — Sistema de Logística"
        Height="560" Width="900"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="Button" x:Key="NavButton">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Foreground" Value="#D8DEE9"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent" Margin="8,2" CornerRadius="6">
                            <Grid>
                                <Border x:Name="Accent" Width="4" HorizontalAlignment="Left"
                                        Background="Transparent" CornerRadius="6,0,0,6"/>
                                <ContentPresenter x:Name="Cp" HorizontalAlignment="Left"
                                                  VerticalAlignment="Center" Margin="16,0,12,0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3B4252"/>
                                <Setter TargetName="Accent" Property="Background" Value="#616E88"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="ativa">
                                <Setter TargetName="Bd" Property="Background" Value="#434C5E"/>
                                <Setter TargetName="Accent" Property="Background" Value="#88C0D0"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#6B7280"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Menu lateral -->
        <Border Grid.Column="0" Background="#2E3440">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="MERCADINHO"
                           Foreground="#88C0D0" FontWeight="Bold" FontSize="16"
                           Margin="16,20,16,20"/>

                <StackPanel DockPanel.Dock="Top">
                    <Button x:Name="BtnInicio" Style="{StaticResource NavButton}"
                            Content="🏠  Início" Click="BtnInicio_Click"/>
                    <Button x:Name="BtnCadastroMercadoria" Style="{StaticResource NavButton}"
                            Content="➕  Cadastro de Mercadoria" Click="BtnCadastroMercadoria_Click"/>
                    <Button x:Name="BtnManterMercadorias" Style="{StaticResource NavButton}"
                            Content="📦  Manter Mercadorias" Click="BtnManterMercadorias_Click"/>
                    <Button x:Name="BtnClientes" Style="{StaticResource NavButton}"
                            Content="👥  Clientes" Click="BtnClientes_Click"/>
                    <Button x:Name="BtnPdv" Style="{StaticResource NavButton}"
                            Content="🛒  Vendas (PDV)" Click="BtnPdv_Click"/>
                    <Button x:Name="BtnHistorico" Style="{StaticResource NavButton}"
                            Content="📜  Histórico de Vendas" Click="BtnHistorico_Click"/>
                    <Button x:Name="BtnRelatorio" Style="{StaticResource NavButton}"
                            Content="📊  Relatório de Lucros" Click="BtnRelatorio_Click"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="16,0,16,12" VerticalAlignment="Bottom">
                    <Border x:Name="StatusBanco" CornerRadius="10" Background="#2E7D32"
                            Padding="10,4" HorizontalAlignment="Left" Margin="0,0,0,6">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="#A5D6A7" VerticalAlignment="Center"/>
                            <TextBlock x:Name="StatusBancoText" Text="Banco conectado"
                                       Foreground="White" FontSize="12" Margin="6,0,0,0"/>
                        </StackPanel>
                    </Border>
                    <TextBlock x:Name="VersaoText" Text="v1.2.0"
                               Foreground="#4C566A" FontSize="11"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Conteúdo -->
        <ContentControl x:Name="ContentArea" Grid.Column="1"/>
    </Grid>
</Window>
