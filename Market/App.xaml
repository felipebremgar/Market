<Application x:Class="Market.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrls="clr-namespace:Market.UI.Controls">
    <Application.Resources>
        <!-- Exibe o empty state quando o grid não tem itens (HasItems=false → Visible). -->
        <ctrls:InverseBooleanToVisibilityConverter x:Key="BoolInverteVis"/>

        <!-- Mensagem central para grids vazios. -->
        <Style TargetType="TextBlock" x:Key="EmptyState">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#8A94A6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="MaxWidth" Value="280"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
        </Style>

        <!-- Tabelas com fonte e altura de linha maiores, para leitura rápida no caixa. -->
        <Style TargetType="DataGrid">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="RowHeight" Value="28"/>
        </Style>
    </Application.Resources>
</Application>
